{
  "name": "@stm/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.cjs",
  "scripts": {
    "dev": "tsx watch src/bin/server.ts",
    "start": "tsx src/bin/server.ts",
    "bundle": "esbuild src/bin/server.ts --bundle --platform=node --format=cjs --external:better-sqlite3 --outfile=dist/server.cjs",
    "build": "pnpm bundle",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@stm/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "fastify": "^5.2.1",
    "opencc-js": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.6",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
