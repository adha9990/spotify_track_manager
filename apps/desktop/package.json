{
  "name": "@stm/desktop",
  "version": "0.3.0",
  "private": true,
  "main": "dist/main.cjs",
  "scripts": {
    "build:main": "esbuild src/main.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/main.cjs",
    "build:preload": "esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs",
    "build": "pnpm build:main && pnpm build:preload",
    "dev": "pnpm --filter @stm/backend bundle && pnpm build && electron .",
    "stage": "node scripts/stage.mjs",
    "rebuild:native": "electron-rebuild -m build/backend -o better-sqlite3",
    "dist": "pnpm stage && pnpm rebuild:native && electron-builder",
    "dist:dir": "pnpm stage && pnpm rebuild:native && electron-builder --dir",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/node": "^22.10.6",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3"
  }
}
