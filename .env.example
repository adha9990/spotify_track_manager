# Spotify API 憑證(必填)
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# OAuth 重新導向網址(需與 Spotify Dashboard 設定一致)
# Spotify 不接受 http://localhost(視為 insecure),請用回送位址 127.0.0.1
REDIRECT_URI=http://127.0.0.1:8888/callback

# 報表輸出檔(選填,預設 spotify_report.html;等同 scan 的 --output)
OUTPUT_FILE=spotify_report.html

# 選填:web player 的 sp_dc cookie,設了 serve 才會抓「播放次數」(非官方、會壞)
# 取得:登入 open.spotify.com → F12 → Application → Cookies → 複製 sp_dc 的值
# 注意:這走 Spotify 內部 API,secret 被輪換時該欄會留白,不影響其他功能
SP_DC=
